DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
DATABASE_NAME=avapharmacy
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
DJANGO_SETTINGS_MODULE=avapharmacy.settings.development
MEDIA_URL=/media/
STATIC_URL=/static/
REDIS_URL=redis://localhost:6379

# Frontend / App URLs
BACKEND_BASE_URL=http://127.0.0.1:8000
FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_LOGIN_URL=http://localhost:3000/login
FRONTEND_PHARMACIST_DASHBOARD_URL=http://localhost:3000/pharmacist/dashboard
FRONTEND_PHARMACIST_ACTIVATION_PATH=/auth/pharmacist/activate

# Checkout / Payments
PAYMENT_WEBHOOK_SECRET=replace-with-random-shared-secret
FREE_SHIPPING_THRESHOLD=3000
SHIPPING_FEE=300

# M-Pesa Daraja
# Use `sandbox` for Safaricom test credentials, `production` for live credentials.
MPESA_ENVIRONMENT=sandbox
# Daraja app credentials from Safaricom developer portal.
MPESA_CONSUMER_KEY=your-daraja-consumer-key
MPESA_CONSUMER_SECRET=your-daraja-consumer-secret
# Business shortcode / paybill / till used for STK push.
MPESA_SHORTCODE=174379
# Lipa Na M-Pesa Online passkey for the shortcode above.
MPESA_PASSKEY=your-daraja-passkey
# Must be a public backend URL reachable by Safaricom, ending with this API path.
MPESA_CALLBACK_URL=https://your-backend.example.com/api/payments/mpesa/callback/
# Usually CustomerPayBillOnline for STK push.
MPESA_TRANSACTION_TYPE=CustomerPayBillOnline
MPESA_TIMEOUT_SECONDS=30

# Flutterwave Card Payments
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_SECRET_HASH=
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com
FLUTTERWAVE_TIMEOUT_SECONDS=30
FLUTTERWAVE_REDIRECT_URL=http://localhost:3000/checkout

# POS / Order Push
POS_ORDER_PUSH_URL=
POS_ORDER_PUSH_TOKEN=
POS_ORDER_PUSH_TIMEOUT_SECONDS=15
POS_ORDER_PUSH_MAX_ATTEMPTS=3
POS_ORDER_PUSH_BACKOFF_SECONDS=1.0
POS_ORDER_PUSH_MAX_BACKOFF_SECONDS=8.0
POS_ORDER_PUSH_QUEUE_MAX_ATTEMPTS=10
